# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=

# n8n Cloud (IaC workflow management)
N8N_BASE_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=
N8N_STRAVA_WEBHOOK_URL=

# AI providers (OpenAI-compatible -- default: Groq)
GROQ_API_KEY=
# Optional overrides for non-Groq OpenAI-compatible providers:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=qwen/qwen3-32b
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Session
SESSION_SECRET=

# Internal
CONVEX_WEBHOOK_SECRET=
INTERNAL_API_TOKEN=

# App URL (set in Convex env vars for LangChain analysis trigger)
# In dev: http://localhost:3000  In prod: https://your-vercel-url.vercel.app
APP_URL=http://localhost:3000

# Vercel (CLI deploys)
VERCEL_TOKEN=
