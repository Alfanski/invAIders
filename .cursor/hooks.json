{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/format.sh",
        "matcher": "Write"
      }
    ],
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-init.sh"
      }
    ],
    "preCompact": [
      {
        "command": ".cursor/hooks/pre-compact.sh"
      }
    ]
  }
}
