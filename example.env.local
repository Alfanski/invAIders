# Copy this file to .env.local and fill in your values
# cp example.env.local .env.local

# Vercel CLI auth (optional — only needed for `vercel` CLI deploys)
# Generate at https://vercel.com/account/tokens
export VERCEL_TOKEN='your_vercel_token_here'

# Strava API (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID='214497'
STRAVA_CLIENT_SECRET='8556faa749150f6dd60e0ba9fc0d19b53bf35728'
STRAVA_REDIRECT_URI='https://invaiders.vercel.app/api/auth/strava/callback'
STRAVA_WEBHOOK_VERIFY_TOKEN='mAIVerifyToken'

# Convex — auto-populated by `npx convex dev`
# NEXT_PUBLIC_CONVEX_URL='https://your-deployment.convex.cloud'
# CONVEX_WEBHOOK_SECRET='your_convex_webhook_secret'
